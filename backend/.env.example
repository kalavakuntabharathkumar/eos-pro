# Enterprise OS — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — JWT signing key. Use a long random string (e.g. openssl rand -hex 32).
SECRET_KEY=your-secret-key-here

# Optional — URL of the frontend (used for CORS).
FRONTEND_URL=http://localhost:5173

# Optional — AI Copilot keys. The copilot falls back to canned responses if absent.
OPENROUTER_API_KEY=your-openrouter-key
GEMINI_API_KEY=your-gemini-key

# Optional — SQLite database path. Defaults to ./enterprise_os.db.
# ENTERPRISE_DB_URL=sqlite:///./enterprise_os.db
